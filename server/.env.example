LLM_API_KEY=your_longcat_api_key_here
LLM_BASE_URL=https://api.longcat.chat/openai/v1
LLM_MODEL=LongCat-2.0
ASR_MODEL_DIR=./models/SenseVoiceSmall #https://huggingface.co/FunAudioLLM/SenseVoiceSmall
#https://github.com/FunAudioLLM/SenseVoice

# 企业微信配置（可选）
WECOM_CORP_ID=your_corp_id
WECOM_CORP_SECRET=your_corp_secret
WECOM_AGENT_ID=your_agent_id
WECOM_TOKEN=your_token
WECOM_ENCODING_AES_KEY=your_encoding_aes_key
WECOM_CALLBACK_URL=https://your-domain.com/wecom/callback
